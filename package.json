{
	"name": "bikeapelago",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:all": "npm run test && npm run test:e2e"
	},
	"devDependencies": {
		"@markw65/fit-file-writer": "^0.1.9",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^6.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"@vitest/coverage-v8": "^4.1.2",
		"autoprefixer": "^10.4.16",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.30.0",
		"gpxparser": "^3.0.8",
		"postcss": "^8.4.32",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"sharp-cli": "^5.2.0",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tailwindcss": "^3.4.0",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^4.1.2"
	},
	"type": "module",
	"dependencies": {
		"@airbreather/archipelago.js": "2.0.5-airbreather.6",
		"@raruto/leaflet-elevation": "^2.5.1",
		"@sports-alliance/sports-lib": "^5.4.24",
		"@sveltejs/adapter-node": "^2.0.2",
		"express": "^4.18.2",
		"fit-file-parser": "^1.9.5",
		"image-conversion": "^2.1.1",
		"leaflet": "^1.9.4",
		"leaflet-control-geocoder": "^2.4.0",
		"leaflet-routing-machine": "^3.2.12",
		"leaflet-simple-map-screenshoter": "^0.5.0",
		"lrm-graphhopper": "^1.3.0",
		"pocketbase": "^0.20.3",
		"sharp": "^0.34.5"
	}
